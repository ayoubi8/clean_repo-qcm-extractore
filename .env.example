# ══════════════════════════════════════════════════════════════════
#  QCM EXTRACTOR — .env configuration template
#  Edit only this file to change models. Never touch .py files.
# ══════════════════════════════════════════════════════════════════

# ── Deployment URLs ───────────────────────────────────────────────
# The public URL of your frontend (used by backend for OAuth redirect)
# On HF Spaces set this as a Space Secret named FRONTEND_URL
FRONTEND_URL=https://qcm-extractor-frontend.vercel.app


# ── Core API (ONE key used for ALL steps) ─────────────────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Step 1: OCR Vision (image → text) ────────────────────────────
STEP1_MODEL=qwen/qwen3-vl-30b-a3b-instruct
STEP1_FALLBACK_MODEL=qwen/qwen-2.5-vl-7b-instruct:free
STEP1_MAX_TOKENS=15000

# ── Step 1.5: Text Split Fixer ────────────────────────────────────
STEP1_5_MODEL=google/gemma-3-27b-it:free
STEP1_5_FALLBACK_MODEL=google/gemini-2.0-flash-lite-001
STEP1_5_MAX_TOKENS=8000

# ── Step 1.6: Intelligent OCR Text Corrector ──────────────────────
STEP1_6_MODEL=meta-llama/llama-3.3-70b-instruct
STEP1_6_FALLBACK_MODEL=google/gemini-2.0-flash-lite-001
STEP1_6_MAX_TOKENS=4000

# ── Step 2: QCM Extraction ────────────────────────────────────────
STEP2_MODEL=google/gemini-2.5-flash-lite-preview-09-2025
STEP2_FALLBACK_MODEL=nvidia/nemotron-3-super-120b-a12b:free
STEP2_MAX_TOKENS=20000

# ── Step 3: Metadata Detection ────────────────────────────────────
STEP3_MODEL=google/gemma-3-27b-it
STEP3_FALLBACK_MODEL=google/gemini-2.0-flash-lite-001
STEP3_MAX_TOKENS=4000

# ── Step 6: Correction Page Parser (text tables) ─────────────────
STEP6_TEXT_MODEL=nvidia/nemotron-3-nano-30b-a3b:free
STEP6_TEXT_FALLBACK_MODEL=google/gemini-2.0-flash-lite-001
STEP6_TEXT_MAX_TOKENS=4000

# ── Step 6: All-Pages Scan (big context window) ───────────────────
STEP6_ALL_PAGES_MODEL=google/gemini-2.5-flash-lite-preview-09-2025
STEP6_ALL_PAGES_FALLBACK_MODEL=google/gemini-2.0-flash-001
STEP6_ALL_PAGES_MAX_TOKENS=4000

# ── Step 6: AI-Knowledge Mode (DeepSeek reasoning) ───────────────
STEP6_AI_MODEL=deepseek/deepseek-r1-distill-llama-70b
STEP6_AI_FALLBACK_MODEL=deepseek/deepseek-r1
STEP6_AI_MAX_TOKENS=4000

# ── Step 7: Categorization ────────────────────────────────────────
STEP7_MODEL=meta-llama/llama-3.3-70b-instruct
STEP7_FALLBACK_MODEL=google/gemini-2.0-flash-lite-001
STEP7_MAX_TOKENS=4000

# ── Caching ───────────────────────────────────────────────────────
ENABLE_CACHING=true

# ── Step 8: QCM Similarity Matcher ──────────────────────────────────
# Path to your reference database (.xlsx or .json)
REFERENCE_DB_PATH=path_to_reference_db
MATCH_THRESHOLD=0.75

# Similarity mode: text_only | full | weighted
MATCH_MODE=text_only

# Weights used only in 'weighted' mode (must sum to 1.0)
MATCH_TEXT_WEIGHT=0.7
MATCH_CORRECTION_WEIGHT=0.3

# XLSX report color thresholds (similarity score boundaries)
MATCH_COLOR_GREEN=0.90
MATCH_COLOR_YELLOW=0.75
